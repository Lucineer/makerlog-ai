# makerlog-ai — Environment Variables
# Copy to .env and fill in values before running docker-compose.

# LLM Provider (deepseek | anthropic | openai | groq | ollama)
COCAPN_PROVIDER=deepseek

# API Keys — only set keys for providers you use
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# Local model host (used when COCAPN_PROVIDER=ollama)
OLLAMA_HOST=http://ollama:11434

# Billing
BILLING_ENABLED=false

# Webhook verification secret (shared with Telegram / Discord)
WEBHOOK_SECRET=

# Port for the host-mapped service
PORT=3000
